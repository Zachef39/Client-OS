# Faerber Client OS — required env vars for cloud (Railway) deploy.
# Copy real values from ~/Desktop/Playground - Claude/.env when pasting into Railway.
# Never commit this file with real values — the .gitignore excludes .env, not .env.example.

# ─── Deploy mode ────────────────────────────────────────────────
# Railway/Docker: leave LOCAL_ONLY unset (or set to "false"). Endpoints that
# spawn Python / Playwright / read Mac desktop paths will 501 cleanly.
# On the local Mac wrapper: set LOCAL_ONLY=true to enable those endpoints.
LOCAL_ONLY=false
NODE_ENV=production
# PORT is injected by Railway automatically — do NOT set it in the dashboard.

# ─── Dashboard basic auth (REQUIRED in cloud) ───────────────────
# Gates the entire /v2 dashboard + /api/* surface behind HTTP Basic Auth.
# /api/health stays public so Railway's healthcheck still works.
# If DASHBOARD_PASSWORD is unset, the middleware falls through (local dev).
# Set BOTH in Railway → Variables. Use a long random password.
DASHBOARD_USER=zach
DASHBOARD_PASSWORD=<REDACTED — set a strong random password in Railway>


# ─── Anthropic (Claude) ────────────────────────────────────────
# If the value in ~/.env has a doubled "sk-ant-sk-ant-" prefix, the server strips it.
ANTHROPIC_API_KEY=<REDACTED — fill from ~/Desktop/Playground - Claude/.env>

# ─── Supabase ──────────────────────────────────────────────────
# SUPABASE_URL comes from ~/.env. SUPABASE_KEY should be the service role key
# for full read/write (many /api/v2/* endpoints write). Fall back to anon if
# read-only surface is enough.
SUPABASE_URL=<REDACTED — fill from ~/Desktop/Playground - Claude/.env>
SUPABASE_KEY=<REDACTED — use SUPABASE_SERVICE_ROLE_KEY value>
SUPABASE_SERVICE_KEY=<REDACTED — same as SUPABASE_KEY, some modules read this name>
SUPABASE_SERVICE_ROLE_KEY=<REDACTED — same as SUPABASE_KEY, some modules read this name>
SUPABASE_ANON_KEY=<REDACTED — optional fallback>

# ─── Monday.com ────────────────────────────────────────────────
MONDAY_API_TOKEN=<REDACTED — fill from ~/Desktop/Playground - Claude/.env>
MONDAY_BOARD_ID=18372257888

# ─── Trainerize (v03 REST API) ─────────────────────────────────
TRAINERIZE_GROUP_ID=<REDACTED>
TRAINERIZE_API_TOKEN=<REDACTED>

# ─── GoHighLevel (booked calls API) ────────────────────────────
GHL_API_KEY=<REDACTED — Private Integration Token>
GHL_LOCATION_ID=<REDACTED>
GHL_SALES_CALENDAR_IDS=<REDACTED — comma-separated>
GHL_DISCOVERY_CALENDAR_IDS=<REDACTED — comma-separated>

# ─── Meta Ads (Facebook Graph API) ─────────────────────────────
META_ADS_TOKEN=<REDACTED — long-lived page token>
META_AD_ACCOUNT_ID=<REDACTED — format: act_1234567890>

# ─── Stripe (P&L revenue — three accounts) ─────────────────────
# Server reads all three; missing keys just skip that account in the totals.
STRIPE_SK_MEDICAL=<REDACTED>
STRIPE_SK_PANDADOC=<REDACTED>
STRIPE_SK_AFFIRM=<REDACTED>

# ─── Slack (optional — used by ops notifications) ──────────────
SLACK_WEBHOOK=<REDACTED — optional>

# ─── Resend (email notifications — optional) ───────────────────
RESEND_API_KEY=<REDACTED — optional>
RESEND_FROM_EMAIL=<REDACTED — optional, defaults to onboarding@resend.dev>
NOTIFY_EMAIL=zacharyfaerber@gmail.com
